# Google Wallet Integration
# Kopiere diese Datei als .env.local und fülle die Werte aus.
# .env.local darf NIEMALS ins Git-Repository eingecheckt werden!

# Issuer ID aus der Google Wallet Business Console (numerisch, z.B. 3388000000012345678)
GOOGLE_WALLET_ISSUER_ID=

# E-Mail-Adresse des Service Accounts (aus Google Cloud IAM)
# Format: mein-service-account@mein-projekt.iam.gserviceaccount.com
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=

# Privater RSA-Schlüssel des Service Accounts (aus der JSON-Schlüsseldatei, Feld "private_key")
# Zeilenumbrüche (\n) müssen als Literal \n gespeichert werden, z.B.:
# GOOGLE_WALLET_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
GOOGLE_WALLET_PRIVATE_KEY=
